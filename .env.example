# ============================================================
#  TRATO HECHO - Variables de Entorno
#  Copia este archivo a .env y completa los valores reales
#  NUNCA subas .env a git (ya está en .gitignore)
# ============================================================

# ── n8n ──────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=cambia_esto_123

# URL pública de tu instancia n8n
# Desarrollo: http://localhost:5678/
# Producción: https://n8n.tudominio.cl/
WEBHOOK_URL=http://localhost:5678/
N8N_PROTOCOL=http

# ── Claude / Anthropic ───────────────────────────────────────
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-XXXXXXXXXXXXXXXXXXXX

# ── MercadoPago ──────────────────────────────────────────────
# Obtén tu Access Token en: https://www.mercadopago.cl/developers/panel
# Usa el token de PRUEBA para testing (empieza con TEST-)
# Usa el token de PRODUCCIÓN para cobros reales (empieza con APP_USR-)
MERCADOPAGO_ACCESS_TOKEN=TEST-XXXXXXXXXXXXXXXXXXXX

# ── Frontend ─────────────────────────────────────────────────
# URL donde corre el frontend (para redirección post-pago)
FRONTEND_URL=http://localhost:3000
